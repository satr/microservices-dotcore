@page
@model LibraryWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Library";
}

<h2>Library</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<partial name="Shared/_CartFailures" model="Model.Failures" />

@if (string.IsNullOrWhiteSpace(Model.CurrentUserId))
{
    <form method="post" asp-page-handler="Login" class="mb-4">
        <label for="UserName" class="form-label">User name</label>
        <input asp-for="UserName" class="form-control" />
        <button type="submit" class="btn btn-primary mt-2">Login</button>
        <div class="form-text">Try: user1 or user2</div>
    </form>
}
else
{
    <div class="mb-3">
        Logged in as <strong>@Model.CurrentUserName</strong>
        <form method="post" asp-page-handler="Logout" class="d-inline">
            <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">Logout</button>
        </form>
        <a asp-page="/Cart" class="btn btn-sm btn-outline-primary ms-2">Cart</a>
    </div>
}

<form method="post" asp-page-handler="Search" class="mb-3">
    <label for="SearchQuery" class="form-label">Search books</label>
    <div class="input-group">
        <input asp-for="SearchQuery" class="form-control" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Books.Count > 0)
{
    <ul class="list-group">
        @foreach (var book in Model.Books)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@book.Title</strong> - @book.Author
                </div>
                <form method="post" asp-page-handler="AddToCart" class="d-inline">
                    <input type="hidden" name="bookId" value="@book.Id" />
                    <input type="hidden" name="title" value="@book.Title" />
                    <input type="hidden" name="author" value="@book.Author" />
                    <input type="hidden" asp-for="SearchQuery" />
                    <button type="submit" class="btn btn-success btn-sm">Add to Cart</button>
                </form>
            </li>
        }
    </ul>
}
