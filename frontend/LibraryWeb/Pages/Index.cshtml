@page
@model LibraryWeb.Pages.IndexModel
@{
    ViewData["Title"] = "Library";
}

<h2>Library</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<partial name="Shared/_CartFailures" model="Model.Failures" />

@if (!Model.IsAuthenticated)
{
    <div class="mb-4">
        <p class="text-muted">Sign in to search and borrow books.</p>
        <a href="/login" class="btn btn-primary">Login with Keycloak</a>
        <div class="form-text mt-1">Accounts: <strong>user1</strong> / user1 &nbsp;·&nbsp; <strong>user2</strong> / user2 &nbsp;·&nbsp; <strong>librarian1</strong> / librarian1</div>
    </div>
}
else
{
    <div class="mb-3 d-flex align-items-center gap-2">
        Logged in as <strong>@Model.CurrentUserName</strong>
        @if (Model.IsLibrarian)
        {
            <span class="badge bg-warning text-dark">librarian</span>
        }
        else
        {
            <span class="badge bg-primary">member</span>
        }
        <form method="post" action="/logout" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-secondary">Logout</button>
        </form>
        <a asp-page="/Cart" class="btn btn-sm btn-outline-primary">Cart</a>
    </div>
}

<form method="post" asp-page-handler="Search" class="mb-3">
    <label for="SearchQuery" class="form-label">Search books</label>
    <div class="input-group">
        <input asp-for="SearchQuery" class="form-control" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Books.Count > 0)
{
    <ul class="list-group">
        @foreach (var book in Model.Books)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@book.Title</strong> - @book.Author
                    @if (book.Stock < 0)
                    {
                        <span class="badge bg-secondary ms-2">Stock unknown</span>
                    }
                    else if (book.Stock == 0)
                    {
                        <span class="badge bg-danger ms-2">Out of stock</span>
                    }
                    else
                    {
                        <span class="badge bg-success ms-2">@book.Stock available</span>
                    }
                </div>
                <form method="post" asp-page-handler="AddToCart" class="d-inline">
                    <input type="hidden" name="bookId" value="@book.Id" />
                    <input type="hidden" name="title" value="@book.Title" />
                    <input type="hidden" name="author" value="@book.Author" />
                    <input type="hidden" asp-for="SearchQuery" />
                    <button type="submit" class="btn btn-success btn-sm" @(book.Stock == 0 ? "disabled" : "")>Add to Cart</button>
                </form>
            </li>
        }
    </ul>
}
