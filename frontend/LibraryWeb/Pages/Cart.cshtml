@page
@model LibraryWeb.Pages.CartModel
@{
    ViewData["Title"] = "Cart";
}

<h2>Cart</h2>

<div class="mb-3">
    <a asp-page="/Index" class="btn btn-outline-secondary">Home</a>
    @if (!string.IsNullOrWhiteSpace(Model.CurrentUserName))
    {
        <span class="ms-3 text-muted">Logged in as <strong>@Model.CurrentUserName</strong></span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

<partial name="Shared/_CartFailures" model="Model.Failures" />

@if (Model.Items.Count == 0)
{
    <p class="text-muted">Your cart is empty.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var item in Model.Items)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                    <strong>@item.Title</strong> — @item.Author
                </div>
                <form method="post" asp-page-handler="Remove" class="d-inline">
                    <input type="hidden" name="bookId" value="@item.BookId" />
                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                </form>
            </li>
        }
    </ul>

    <form method="post" asp-page-handler="Complete">
        <button type="submit" class="btn btn-primary">Complete Borrowing</button>
    </form>
}

