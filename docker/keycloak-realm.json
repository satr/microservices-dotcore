{
  "realm": "library",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": true,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 3600,
  "clients": [
    {
      "clientId": "library-frontend",
      "name": "Library Frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:5000/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "member",
        "description": "Library member — can browse and borrow books",
        "composite": false,
        "clientRole": false,
        "containerId": "library"
      },
      {
        "name": "librarian",
        "description": "Librarian — can manage books and stock",
        "composite": false,
        "clientRole": false,
        "containerId": "library"
      }
    ]
  },
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "email": "user1@library.local",
      "credentials": [
        {
          "type": "password",
          "value": "user1",
          "temporary": false
        }
      ],
      "realmRoles": ["member"]
    },
    {
      "username": "user2",
      "enabled": true,
      "emailVerified": true,
      "email": "user2@library.local",
      "credentials": [
        {
          "type": "password",
          "value": "user2",
          "temporary": false
        }
      ],
      "realmRoles": ["member"]
    },
    {
      "username": "librarian1",
      "enabled": true,
      "emailVerified": true,
      "email": "librarian1@library.local",
      "credentials": [
        {
          "type": "password",
          "value": "librarian1",
          "temporary": false
        }
      ],
      "realmRoles": ["librarian"]
    }
  ]
}

